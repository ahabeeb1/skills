{
  "description": "habeebs-skill hooks — warn-only SessionStart (ghost-commit detection + peer-scan), block-only PreToolUse on Bash (commits to default branch), warn-only PostToolUse on Edit|Write|NotebookEdit (chain-state validator). All follow ADR-0003: warn-or-block only, multi-harness aware, stateless. Honor HABEEBS_DISABLE_HOOKS=1 for emergency disable.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start-peer-scan.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/preventing-commits-to-default.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pretool-use-peer-scan.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-chain-state.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
